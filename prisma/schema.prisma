// GateForge Central Database Schema (API Key management and analytics)

datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String
  createdAt DateTime @default(now())
}

model ApiConsumer {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  apiKeys     ApiKey[]
}

model ApiKey {
  id          String   @id @default(cuid())

  name        String
  prefix      String

  hashedKey   String

  consumerId  String
  consumer    ApiConsumer @relation(fields: [consumerId], references: [id])

  expiresAt   DateTime?
  revoked     Boolean     @default(false)

  lastUsedAt  DateTime?
  usageCount  Int         @default(0)

  createdAt   DateTime    @default(now())
}

enum HealthStatus {
  HEALTHY
  DEGRADED
  UNHEALTHY
}

enum LoadBalancingStrategy {
  ROUND_ROBIN
  WEIGHTED_ROUND_ROBIN
  LEAST_CONNECTIONS
}

model Service {
  id        String                  @id @default(cuid())
  name      String                  @unique
  basePath  String                  @unique
  strategy  LoadBalancingStrategy   @default(ROUND_ROBIN)
  enabled   Boolean                 @default(true)
  instances ServiceInstance[]
  createdAt DateTime                @default(now())
}

model ServiceInstance {
  id                String       @id @default(cuid())
  serviceId         String
  service           Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  host              String
  port              Int
  weight            Int          @default(1)
  
  healthy           Boolean      @default(true)
  healthStatus      HealthStatus @default(HEALTHY)
  failureCount      Int          @default(0)
  successCount      Int          @default(0)
  lastHealthCheck   DateTime?
  lastHealthyAt     DateTime?
  lastFailureAt     DateTime?
  averageLatency    Float?
  
  activeConnections Int          @default(0)
  createdAt         DateTime     @default(now())
}
