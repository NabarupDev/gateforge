// GateForge Central Database Schema (API Key management and analytics)

datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String
  createdAt DateTime @default(now())
}

model ApiConsumer {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  apiKeys     ApiKey[]
}

model ApiKey {
  id          String   @id @default(cuid())

  name        String
  prefix      String

  hashedKey   String

  consumerId  String
  consumer    ApiConsumer @relation(fields: [consumerId], references: [id])

  expiresAt   DateTime?
  revoked     Boolean     @default(false)

  lastUsedAt  DateTime?
  usageCount  Int         @default(0)

  createdAt   DateTime    @default(now())
}
