{
  "name": "gateforge-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "GateForge Monorepo - API Gateway and Backend Services",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm -r test:e2e",
    "test:e2e:api-keys": "tsx scripts/test-api-keys.ts",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "start:gateway": "pnpm --filter @gateforge/gateway start:dev",
    "start:user": "pnpm --filter @gateforge/user-service start:dev",
    "start:order": "pnpm --filter @gateforge/order-service start:dev",
    "start:ai": "pnpm --filter @gateforge/ai-service start:dev"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.23.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "prisma": "^7.8.0"
  }
}
